eval "$(starship init bash)"

[ -f ~/.local/share/fzf/key-bindings.bash ] && source ~/.local/share/fzf/key-bindings.bash

for f in ~/.config/shell/{exports,aliases,functions,local}.sh; do
  [ -r "$f" ] && . "$f"
done

# aliases override
alias gaa="git add -A"
alias gst="git status"
alias gcmsg="git commit -m"
alias gp="git push"

