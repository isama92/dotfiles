# Ghostty's website: https://ghostty.org/docs/config
# reload config: Command + Shift + comma

gtk-titlebar = false
gtk-wide-tabs = false
window-height = 33
window-width = 100
background-opacity = 0.90
shell-integration-features = no-cursor
cursor-style = block 
shell-integration = zsh
window-theme = light

theme = Catppuccin Latte

font-family = "MesloLGS NF"
font-thicken = true
font-size = 16

mouse-hide-while-typing = true

# multiline with shift enter
keybind = shift+enter=text:\x1b\r

#   new tab    -> ctrl+shift+t
#   fullscreen -> ctrl+enter
#   new window -> ctrl+shift+n
#   search     -> ctrl+shift+f
keybind = ctrl+w=unbind
keybind = ctrl+n=unbind
keybind = ctrl+f=unbind
keybind = ctrl+q=unbind

